// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// APP MODELS
// ─────────────────────────────────────────────

model Log {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime
  location      String?
  // Visibility range in metres (e.g. 5–7m stored as min: 5, max: 7)
  visibilityMin Int?
  visibilityMax Int?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sightings     Sighting[]
  photos        Photo[]

  @@index([userId])
}

// Join table between Log and Species (many-to-many).
// One row = one species spotted on one dive.
model Sighting {
  id        String  @id @default(cuid())
  logId     String
  log       Log     @relation(fields: [logId], references: [id], onDelete: Cascade)
  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  notes     String?
  count     Int?

  @@index([logId])
  @@index([speciesId])
}

// Global reference table — shared across all users.
// Seeded with common marine species.
model Species {
  id             String     @id @default(cuid())
  commonName     String     @unique
  scientificName String?
  description    String?
  sightings      Sighting[]
}

model Photo {
  id        String   @id @default(cuid())
  logId     String
  log       Log      @relation(fields: [logId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime @default(now())

  @@index([logId])
}

// ─────────────────────────────────────────────
// AUTH MODELS (Better Auth)
// ─────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  logs          Log[]
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}
